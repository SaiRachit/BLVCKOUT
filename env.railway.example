# Copy patterns into Railway → Project → each Service → Variables.
# Reference syntax (in the Railway UI only): ${{ServiceName.VARIABLE}}

# -----------------------------------------------------------------------------
# Redis (add the “Redis” template or Valkey; use the URL variable it provides)
# -----------------------------------------------------------------------------
# Prefer Railway’s REDIS_URL; this app also accepts STREAM_URL if you set it instead.
# STREAM_URL=${{Redis.REDIS_URL}}
# Or leave STREAM_URL unset and rely on REDIS_URL (supported in code).

# -----------------------------------------------------------------------------
# api-service  → Dockerfile: services/api_service/Dockerfile  (context: repo root)
# -----------------------------------------------------------------------------
# SERVICE_NAME=api-service
# PYTHONPATH=/app
# Use private HTTP base URLs (see RAILWAY.md) or public https://… domains.
# AUTH_SERVICE_URL=http://auth.railway.internal:8080
# CACHE_SERVICE_URL=http://cache.railway.internal:8080
# DATABASE_SERVICE_URL=http://database.railway.internal:8080
# EVENT_PROCESSOR_SERVICE_URL=http://event-processor.railway.internal:8080
# RCA_SERVICE_URL=http://rca.railway.internal:8080
# SYNTHETIC_GENERATOR_SERVICE_URL=http://synthetic-generator.railway.internal:8080
# PAYMENT_SERVICE_URL=http://payment.railway.internal:8080
# NOTIFICATION_SERVICE_URL=http://notification.railway.internal:8080
# API_SERVICE_URL is only needed for export/metrics aggregation; use your public API URL if set.
# API_SERVICE_URL=https://${{API.RAILWAY_PUBLIC_DOMAIN}}

# -----------------------------------------------------------------------------
# auth-service  → services/auth_service/Dockerfile
# -----------------------------------------------------------------------------
# SERVICE_NAME=auth-service
# CACHE_SERVICE_URL=http://cache.railway.internal:8080

# -----------------------------------------------------------------------------
# cache-service  → services/cache_service/Dockerfile
# -----------------------------------------------------------------------------
# SERVICE_NAME=cache-service
# DATABASE_SERVICE_URL=http://database.railway.internal:8080

# -----------------------------------------------------------------------------
# database-service  → services/database_service/Dockerfile
# -----------------------------------------------------------------------------
# SERVICE_NAME=database-service

# -----------------------------------------------------------------------------
# payment-service  → services/payment_service/Dockerfile
# -----------------------------------------------------------------------------
# SERVICE_NAME=payment-service
# DATABASE_SERVICE_URL=http://database.railway.internal:8080
# NOTIFICATION_SERVICE_URL=http://notification.railway.internal:8080

# -----------------------------------------------------------------------------
# notification-service  → services/notification_service/Dockerfile
# -----------------------------------------------------------------------------
# SERVICE_NAME=notification-service

# -----------------------------------------------------------------------------
# event-processor-service  → services/event_processor_service/Dockerfile
# -----------------------------------------------------------------------------
# SERVICE_NAME=event-processor-service
# Optional tuning (defaults exist): LATENCY_THRESHOLD_MS, WINDOW_SECONDS, etc.

# -----------------------------------------------------------------------------
# synthetic-generator-service  → services/synthetic_generator_service/Dockerfile
# -----------------------------------------------------------------------------
# SYNTHETIC_GENERATOR_ENABLED=true
# AUTO_CHAOS_ENABLED=true

# -----------------------------------------------------------------------------
# rca-service  → services/rca_service/Dockerfile
# -----------------------------------------------------------------------------
# SERVICE_NAME=rca-service

# -----------------------------------------------------------------------------
# remediation-service  → services/remediation_service/Dockerfile
# -----------------------------------------------------------------------------
# SERVICE_NAME=remediation-service
# CACHE_SERVICE_URL=http://cache.railway.internal:8080
# AUTH_SERVICE_URL=http://auth.railway.internal:8080
# DATABASE_SERVICE_URL=http://database.railway.internal:8080
# PAYMENT_SERVICE_URL=http://payment.railway.internal:8080
# NOTIFICATION_SERVICE_URL=http://notification.railway.internal:8080
# SYNTHETIC_GENERATOR_URL=http://synthetic-generator.railway.internal:8080

# -----------------------------------------------------------------------------
# Port note
# -----------------------------------------------------------------------------
# Replace 8080 with the port your containers actually listen on. Railway sets $PORT
# at runtime; our Dockerfiles use ${PORT:-800x}. On Railway, $PORT is set (often the
# same integer for every service), so internal URLs should use that value for all hosts.
